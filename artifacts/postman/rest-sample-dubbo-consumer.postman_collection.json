    {
      "name": "Customer Commands",
      "item": [
        {
          "name": "POST Create Customer - JSON byte[] pass-through",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200 || pm.response.code === 201) {",
                  "  const body = pm.response.json();",
                  "  const id = body.customerId || (body.customer && body.customer.id);",
                  "  if (id) pm.collectionVariables.set('customerId', String(id));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customerNo\": \"PM-BYTE-{{$timestamp}}\",\n  \"fullName\": \"Postman Byte Customer\",\n  \"segment\": \"{{segment}}\",\n  \"email\": \"postman-byte@example.com\",\n  \"requestId\": \"pm-byte-{{$timestamp}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/customers",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "customers"
              ]
            },
            "description": "REST receives JSON bytes and forwards them to Dubbo as byte[]. This is the lower-overhead command path."
          },
          "response": []
        },
        {
          "name": "POST Create Customer - Typed record",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200 || pm.response.code === 201) {",
                  "  const body = pm.response.json();",
                  "  const id = body.customerId || (body.customer && body.customer.id);",
                  "  if (id) pm.collectionVariables.set('customerId', String(id));",
                  "}"
