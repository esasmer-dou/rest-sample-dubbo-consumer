              "raw": "{\n  \"customerNo\": \"PM-TYPED-{{$timestamp}}\",\n  \"fullName\": \"Postman Typed Customer\",\n  \"segment\": \"{{segment}}\",\n  \"email\": \"postman-typed@example.com\",\n  \"requestId\": \"pm-typed-{{$timestamp}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/customers/typed",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "customers",
                "typed"
              ]
            },
            "description": "REST parses request body into CreateCustomerCommand record, then calls the typed Dubbo method."
          },
          "response": []
